# Hidden Gem Backend - Environment Configuration

# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL with PostGIS)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=hiddenGem
DATABASE_USER=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_in_production

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth - Apple
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_CLIENT_ID=com.hidden-gem.app

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_SERVICE_ACCOUNT_PATH=./hedeen-650b5-firebase-adminsdk-fbsvc-1dd5b22b9e.json

# AWS S3 (Optional - for image storage)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=hidden-gem-media
AWS_CLOUDFRONT_DOMAIN=optional_cloudfront_domain.cloudfront.net

# Email Service (Optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@hiddengem.app

# Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_PER_REQUEST=10

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=debug
