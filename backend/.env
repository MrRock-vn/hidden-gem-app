# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=hidden_gem

# JWT
JWT_SECRET=hidden-gem-super-secret-key-change-in-production
JWT_REFRESH_SECRET=hidden-gem-refresh-secret-key-change-in-production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# AWS S3 Configuration
# Set to actual keys to enable S3 uploads (will fallback to local storage otherwise)
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=hidden-gem-media
AWS_REGION=ap-southeast-1
# Optional: CloudFront domain for serving images (faster CDN)
AWS_CLOUDFRONT_DOMAIN=

# Firebase Configuration for Push Notifications
# Download from Firebase Console: Project Settings > Service Account > Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# OAuth2 Configuration
# Google OAuth - Get from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
# Apple OAuth - Get from Apple Developer Account
APPLE_CLIENT_ID=your_apple_client_id

# FCM
FCM_SERVER_KEY=your_fcm_key

# Node Environment
NODE_ENV=development

# App
PORT=3000
